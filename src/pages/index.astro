---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Fieldcraft</h1>
				<p class="tagline">Lessons earned by doing. Shared across disciplines.</p>
				<p class="about">
					Every craft holds wisdom that reaches far beyond its own boundaries. A fly fisher, a surgeon, a carpenter, and a trail runner have more to teach each other than they realize. Fieldcraft is where those lessons surface.
				</p>
			</section>

			{posts.length > 0 && (
				<section class="posts">
					<h2>Latest</h2>
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/fieldcraft/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-date">
										{new Date(post.data.pubDate).toLocaleDateString('en-US', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</span>
									{post.data.description && (
										<span class="post-desc">{post.data.description}</span>
									)}
								</a>
							</li>
						))}
					</ul>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2rem 0 3rem;
		border-bottom: 1px solid #e5e5e5;
		margin-bottom: 2rem;
	}
	.hero h1 {
		font-size: 3rem;
		margin: 0 0 0.5rem;
	}
	.tagline {
		font-size: 1.1rem;
		color: #666;
		margin: 0 0 1.5rem;
		font-style: italic;
	}
	.about {
		max-width: 600px;
		line-height: 1.7;
		color: #333;
	}
	.posts h2 {
		margin-bottom: 1rem;
	}
	.posts ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.posts li {
		margin-bottom: 2rem;
	}
	.posts a {
		display: block;
		text-decoration: none;
		color: inherit;
	}
	.posts a:hover .post-title {
		text-decoration: underline;
	}
	.post-title {
		display: block;
		font-size: 1.25rem;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}
	.post-date {
		display: block;
		font-size: 0.85rem;
		color: #888;
		margin-bottom: 0.4rem;
	}
	.post-desc {
		display: block;
		color: #555;
		line-height: 1.5;
	}
</style>
